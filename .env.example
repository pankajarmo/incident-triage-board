# Copy to .env.local and fill in. .env.local is git-ignored — never commit real keys.

# Required for rule 3 (LLM urgency rating). Server-side only; never exposed to the browser.
OPENAI_API_KEY=sk-...

# Optional. Defaults to gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# Phase 4 auth — secret used to sign the session cookie (HMAC-SHA256).
# Generate one with: openssl rand -base64 32
# Required in production; a dev fallback is used locally if unset.
SESSION_SECRET=change-me-with-openssl-rand-base64-32

# Optional. The single email domain allowed to sign in. Defaults to company.com.
# ALLOWED_EMAIL_DOMAIN=company.com
